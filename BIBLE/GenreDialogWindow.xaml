<Window x:Class="BIBLE.GenreDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Жанр" Height="300" Width="400"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="TitleTextBlock" Text="Добавление жанра" FontSize="18" FontWeight="Bold" 
                   Margin="0,0,0,20" Grid.Row="0"/>

        <!-- Поля ввода -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <!-- Название жанра с подсказкой -->
            <Label Content="Название жанра:" FontWeight="Bold"/>
            <TextBox x:Name="NameTextBox" Margin="0,0,0,5" Padding="5"/>
            <TextBlock Text="* Название должно быть уникальным" 
                       FontSize="10" Foreground="Gray" Margin="5,0,0,10"/>

            <!-- Описание -->
            <Label Content="Описание:" FontWeight="Bold"/>
            <TextBox x:Name="DescriptionTextBox" Margin="0,0,0,10" Padding="5" 
                     TextWrapping="Wrap" AcceptsReturn="True" MinLines="3"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="Сохранить" Width="100" Height="35" Margin="5" 
                    Click="SaveButton_Click" IsDefault="True"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="100" Height="35" Margin="5" 
                    Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
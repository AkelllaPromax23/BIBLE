<Window x:Class="BIBLE.GenresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление жанрами" Height="450" Width="600"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Список жанров" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Grid.Row="0"/>

        <DataGrid x:Name="GenresDataGrid" Grid.Row="1" Margin="0,0,0,10" 
                  AutoGenerateColumns="False" IsReadOnly="True" 
                  SelectionMode="Single" AlternatingRowBackground="LightGray">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название жанра" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="250"/>
                <DataGridTextColumn Header="Кол-во книг" Binding="{Binding BookGenres.Count}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="AddButton" Content="Добавить жанр" Width="120" Height="35" Margin="5" 
                    Click="AddButton_Click"/>
            <Button x:Name="EditButton" Content="Редактировать" Width="120" Height="35" Margin="5" 
                    Click="EditButton_Click"/>
            <Button x:Name="DeleteButton" Content="Удалить" Width="120" Height="35" Margin="5" 
                    Click="DeleteButton_Click"/>
            <Button x:Name="CloseButton" Content="Закрыть" Width="120" Height="35" Margin="5" 
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
<Window x:Class="BIBLE.AuthorDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Автор" Height="400" Width="400"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="TitleTextBlock" Text="Добавление автора" FontSize="18" FontWeight="Bold" 
                   Margin="0,0,0,20" Grid.Row="0"/>

        <!-- Поля ввода с прокруткой -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,20">
                <!-- Имя -->
                <Label Content="Имя:" FontWeight="Bold"/>
                <TextBox x:Name="FirstNameTextBox" Margin="0,0,0,5" Padding="5"/>
                <TextBlock Text="* Обязательное поле" 
                           FontSize="10" Foreground="Gray" Margin="5,0,0,10"/>

                <!-- Фамилия -->
                <Label Content="Фамилия:" FontWeight="Bold"/>
                <TextBox x:Name="LastNameTextBox" Margin="0,0,0,5" Padding="5"/>
                <TextBlock Text="* Обязательное поле" 
                           FontSize="10" Foreground="Gray" Margin="5,0,0,10"/>

                <!-- Дата рождения -->
                <Label Content="Дата рождения:" FontWeight="Bold"/>
                <DatePicker x:Name="BirthDatePicker" Margin="0,0,0,5"/>
                <TextBlock Text="* Не может быть в будущем" 
                           FontSize="10" Foreground="Gray" Margin="5,0,0,10"/>

                <!-- Страна (с авто-форматированием) -->
                <Label Content="Страна:" FontWeight="Bold"/>
                <TextBox x:Name="CountryTextBox" Margin="0,0,0,5" Padding="5"/>
                <TextBlock Text="* Обязательное поле. Первая буква автоматически станет заглавной" 
                           FontSize="10" Foreground="Gray" Margin="5,0,0,0"/>
                <TextBlock Text="* Например: Россия, США, Германия" 
                           FontSize="10" Foreground="Gray" Margin="5,0,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="Сохранить" Width="100" Height="35" Margin="5" 
                    Click="SaveButton_Click" IsDefault="True"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="100" Height="35" Margin="5" 
                    Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>